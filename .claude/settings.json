{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[FinPulse] Editing: $CLAUDE_TOOL_INPUT_FILE_PATH'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/rishu/Desktop/FinPulse && if [ -f pyproject.toml ] && command -v ruff &>/dev/null; then ruff check --fix $CLAUDE_TOOL_INPUT_FILE_PATH 2>/dev/null || true; fi"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(ruff:*)",
      "Bash(pytest:*)",
      "Bash(python:*)",
      "Bash(poetry:*)"
    ]
  }
}
